#: libfoundry-gtk/tweaks/foundry-gtk-tweak-provider.c:473
msgid "Highlighting"
msgstr "ການເນັ້ນ"

#: libfoundry-gtk/tweaks/foundry-gtk-tweak-provider.c:479
msgid "Highlight Current Line"
msgstr "ເນັ້ນແຖວປັດຈຸບັນ"

